{
  "name": "GAAI-Ready Skills Repo",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    }
  },
  "postCreateCommand": "bash scripts/install-gaai.sh .",
  "customizations": {
    "vscode": {
      "extensions": [
        "github.copilot",
        "ms-python.python"
      ]
    }
  },
  "remoteUser": "root"
}