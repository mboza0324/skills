# =============================================================================

node_modules/
.pnp
.pnp.js
.pnp.cjs
.pnp.loader.mjs

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Package manager caches
.npm/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
.pnpm-store/

# Keep package lock files tracked by default for apps.
# Uncomment only if this repo is a reusable library and you intentionally do not want lock files.
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# TypeScript
*.tsbuildinfo

