!.vscode/settings.example.json

# JetBrains
.idea/

# Cursor
.cursor/
.cursorignore
.cursorindexingignore

# Vim / Sublime / Emacs
*.swp
*.swo
*~
.project
.workspace

# =============================================================================
# AI Agent / Tooling Safety
# =============================================================================

# Generated agent artifacts
.agent/
.agents/
.agent-cache/
.agent-output/
agent-output/
artifacts/
generated/
scratch/
workspace-share/

# Do not commit local agent memories, scratchpads, or private context
.memory/
.memories/
scratchpad.md
private-notes.md

# =============================================================================
# Docker / Containers
# =============================================================================

.docker/
docker-compose.override.yml

# =============================================================================
# Misc
# =============================================================================

*.zip
*.tar
*.tar.gz
*.rar
*.7z

# Keep README, docs, and universal control files tracked.
!README.md
!AGENT_RULES.md
!ARCHITECTURE.md
!TESTING.md
!SECURITY.md
!DEPLOYMENT.md
!ROADMAP.md
!CHANGELOG.md
!DECISIONS.md
!CONTRIBUTING.md
